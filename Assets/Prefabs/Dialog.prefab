  falas:
  - dublagem: {fileID: 8300000, guid: 411deba8e078445da9e82d2c193e015e, type: 3}
    segmentos:
    - Olhando para o espelho...
    - "O que ele devolve n\xE3o \xE9 voc\xEA..."
    textoAlvo: {fileID: 6749584322828902170}
  - dublagem: {fileID: 8300000, guid: 411deba8e078445da9e82d2c193e015e, type: 3}
    segmentos:
    - "...mas afinal, quem \xE9 voc\xEA?"
    - "oc\xEA se reconhece no reflexo, ou apenas aceita a imagem que o vazio te oferece?"
    textoAlvo: {fileID: 4183060622568781076}
